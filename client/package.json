{
  "name": "financial-data-tracker-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "openapi:fetch": "bun run scripts/openapi-sync.mjs",
    "openapi:gen": "ng-openapi-gen",
    "openapi:update": "bun run openapi:fetch && bun run openapi:gen",
    "start": "bun run openapi:fetch || true && ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "dev": "bun run openapi:fetch || true && ng serve --watch --configuration development --port 4200",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "ng-openapi-gen": "^1.0.5",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
